---
import BaseLayout from "../layouts/BaseLayout.astro";
import Image from "astro/components/Image.astro";
import minionForest from "../assets/minion-forest.jpg";
const imageModules = import.meta.glob("../assets/gallery/*.{jpg,png,webp}", {
	eager: true,
});
const photos = Object.entries(imageModules).map(([_, mod], i) => ({
	src: mod.default,
	alt: `Photo ${i + 1}`,
}));
---

<!doctype html>
<BaseLayout>
	<h1>Welcome to my Page</h1>
	<div class="pictures">
		<div class="gallery">
			{
				photos.map((img, i) => (
					<Image
						src={img.src}
						alt={img.alt}
						width={1200}
						height={675}
						format="webp"
						quality={80}
						loading={
							i === 0
								? "eager"
								: "lazy"
						}
						fetchpriority={
							i === 0
								? "high"
								: "auto"
						}
						style={`animation-delay: ${i * 4}s`}
						class="slide"
					/>
				))
			}
		</div>
		<Image
			src={minionForest}
			alt="minion in the Forest starting at you"
			width={1200}
			height={675}
			class="minion"
		/>
	</div>
</BaseLayout>
<div id="mobile-block">
	<p>This site is only available on desktop.</p>
</div>
<style>
	.pictures {
		position: relative;
		width: min(1080px, 80%);
		height: 80%;
		margin: 0 auto;
		justify-content: center;
		aspect-ratio: 16/9;
		overflow: hidden;
	}
	.minion {
		aspect-ratio: 16/9;
	}
	.gallery img {
		position: absolute;
		aspect-ratio: 16/9;
		opacity: 0;
		animation: slide 12s infinite;
		z-index: 1;
	}
	@keyframes slide {
		0%,
		100% {
			opacity: 0;
		}
		8%,
		25% {
			opacity: 1;
		}
		33% {
			opacity: 0;
		}
	}
	h1 {
		display: flex;
		align-content: center;
		justify-content: center;
		background: linear-gradient(
			90deg,
			red,
			orange,
			yellow,
			green,
			blue,
			indigo,
			violet,
			red
		);
		background-size: 200%;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		animation: rainbow 3s linear infinite;
	}

	@keyframes rainbow {
		0% {
			background-position: 0%;
		}
		100% {
			background-position: 200%;
		}
	}
	.penguin {
		position: relative;
		left: 3rem;
	}
</style>

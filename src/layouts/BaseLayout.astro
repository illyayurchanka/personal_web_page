---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>

	<body>
		<Header />
		<slot />
		<Footer />
		<div id="mobile-block">
			<p>This site is only available on desktop.</p>
		</div>
	</body><style>
		header {
			position: sticky;
		}
	</style>
	<style is:global>
		#mobile-block {
			display: none;
			position: fixed;
			/* width: 1000%; */
			/* height: 1000%; */
			inset: 0;
			background: white;
			z-index: 9999;
			align-items: center;
			justify-content: center;
		}

		@media (max-width: 720px) {
			body {
				background-color: white;
			}
			#mobile-block {
				display: flex;
			}
		}
	</style>
</html>
